# OpeRouter settings. The model MUST support tool calling
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_APP_URL=https://github.com/h-alice/datacenter-agent
OPENROUTER_APP_TITLE=datacenter-agent
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_TEMPERATURE=0.2

# Datacenter MCP endpoint.
DATACENTER_MCP_URL=http://127.0.0.1:8000/mcp

HOST=0.0.0.0
PORT=8080

# Bearer token required on every request: `Authorization: Bearer <GLOBAL_TOKEN>`.
# Request missing or wrong token leads to 418 (teapot). Server refuses to start if unset.
GLOBAL_TOKEN=change-me-before-prod
